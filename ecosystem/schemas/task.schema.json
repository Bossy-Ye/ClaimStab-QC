{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaimStab Ecosystem Task",
  "type": "object",
  "required": ["id", "name", "description", "entrypoint", "claim_types"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "entrypoint": {"type": "string", "minLength": 3},
    "claim_types": {
      "type": "array",
      "items": {"type": "string", "enum": ["ranking", "decision", "distribution", "threshold"]},
      "minItems": 1,
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "version": {"type": "string"},
    "maintainers": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": false
}

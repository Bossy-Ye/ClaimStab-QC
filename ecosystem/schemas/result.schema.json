{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaimStab Ecosystem Result Package",
  "type": "object",
  "required": ["id", "title", "task_id", "suite_id", "generated_at", "command", "artifacts"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "title": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "suite_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 4},
    "command": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "object",
      "required": ["claim_stability", "rq_summary", "scores"],
      "properties": {
        "claim_stability": {"type": "string"},
        "rq_summary": {"type": "string"},
        "scores": {"type": "string"},
        "report": {"type": "string"},
        "figures_manifest": {"type": "string"}
      },
      "additionalProperties": false
    },
    "notes": {"type": "string"},
    "version": {"type": "string"}
  },
  "additionalProperties": false
}
